            "type": "object",
            "required": [
                "code",
                "password",
                "role",
                "username"
            ],
            "properties": {
                "callback_url": {
                    "type": "string"
                },
                "code": {
                    "type": "string"
                },
                "currency": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                },
                "role": {
                    "type": "string",
                    "default": "agent"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "service.UpdateAgentRequest": {
            "type": "object",
            "properties": {
                "callback_url": {
                    "type": "string"
                },
                "code": {
                    "type": "string"
                },
                "currency": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
