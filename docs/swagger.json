                "username"
            ],
            "properties": {
                "password": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "service.CreateAgentRequest": {
            "type": "object",
            "required": [
                "callback_url",
                "code",
                "currency",
                "password",
                "username"
            ],
            "properties": {
                "callback_url": {
                    "type": "string"
